---
import Base from '../layouts/Base.astro';
---
<Base
  title="Page Not Found | SEO.Furniture"
  description="The page you requested could not be found."
>
  <section class="max-w-xl mx-auto px-6 py-24 text-center">
    <h1 class="text-5xl font-bold tracking-tight mb-4">404</h1>
    <p class="text-slate-500 mb-8">Page not found. It may have moved or no longer exists.</p>
    <a href="/" class="inline-block bg-emerald hover:bg-emerald-dark text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">
      Back to home
    </a>
  </section>
</Base>
